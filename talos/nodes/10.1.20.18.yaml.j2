---
machine:
  type: worker
  nodeLabels:
    topology.kubernetes.io/zone: m
    intel.com/gpu-sriov: "true"
  kernel:
    modules:
      - name: vfio
      - name: vfio_iommu_type1
      - name: vfio_pci
  install:
      diskSelector:
          model: '*MZVLB256*'
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: "off"
hostname: main-8
---
apiVersion: v1alpha1
kind: BondConfig
name: bond0
links:
  - eno1np0
  - eno2np1
bondMode: 802.3ad
miimon: 100
updelay: 200
downdelay: 200
xmitHashPolicy: layer2+3
lacpRate: fast